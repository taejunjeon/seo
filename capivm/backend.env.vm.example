NODE_ENV=production
PORT=7020
TRUST_PROXY=1
LOG_LEVEL=info
FRONTEND_ORIGIN=https://biocom.ainativeos.net

# Cutover safety:
# Start the VM with these two disabled while the laptop origin is still alive.
# Enable them only after att.ainativeos.net points to the VM and the laptop backend is stopped.
BACKGROUND_JOBS_ENABLED=true
CWV_AUTO_SYNC_ENABLED=false
CAPI_AUTO_SYNC_ENABLED=false
CAPI_AUTO_SYNC_INTERVAL_MS=1800000
CAPI_AUTO_SYNC_LIMIT=100
ATTRIBUTION_STATUS_SYNC_ENABLED=false
ATTRIBUTION_STATUS_SYNC_INTERVAL_MS=900000
ATTRIBUTION_STATUS_SYNC_LIMIT=100
# Imweb/Toss auto-sync (2026-04-14 added). 초기 컷오버 시엔 false 로 두고, VM 단독 운영 확인 후 true 로 전환.
IMWEB_AUTO_SYNC_ENABLED=false
IMWEB_AUTO_SYNC_INTERVAL_MS=900000
IMWEB_AUTO_SYNC_MAX_PAGE=30
TOSS_AUTO_SYNC_ENABLED=false
TOSS_AUTO_SYNC_INTERVAL_MS=900000
TOSS_AUTO_SYNC_WINDOW_HOURS=6

# Required for CAPI / attribution.
META_ADMANAGER_API_KEY=
META_PIXEL_ID_BIOCOM=1283400029487161
META_APP_SECRET_CODE=

TOSS_SHOP_ID_BIOCOM=
TOSS_LIVE_SECRET_KEY_BIOCOM=
TOSS_LIVE_CLIENT_KEY_BIOCOM=
TOSS_TEST_CLIENT_KEY_BIOCOM=
TOSS_TEST_SECRET_KEY_BIOCOM=

# 2026-04-15 추가 — 커피(더클린커피/팀키토) Toss 신 자회사 merchant iw_theclevibf
# 알로스타에프앤비 산하 신 상점. env.ts v2 fallback chain 은 아래 NEW_COFFEE_* 를 1순위로 읽음.
# 과거 (2026-02-23 이전) 본사 merchant iw_thecleaz5j 는 사용 중지. 구 기간 조회 필요 시에만 별도 보존.
TOSS_SHOP_ID_NEWCOFFEE=
TOSS_NEW_COFFEE_API_SECRET_KEY=
TOSS_NEW_COFFEE_API_LIVE_CLIENT_KEY=
TOSS_NEW_COFFEE_API_SECURITY_KEY_LIVE=
# 구 env.ts 호환용 표준 이름 (동일값 세팅 권장 — code rollout 전/후 둘 다 동작)
TOSS_LIVE_SECRET_KEY_COFFEE=
TOSS_LIVE_CLIENT_KEY_COFFEE=
TOSS_LIVE_SECURITY_KEY_COFFEE=

IMWEB_API_KEY=
IMWEB_SECRET_KEY=

# Optional but used by dashboard/API features.
DATABASE_URL=
GA4_BIOCOM_PROPERTY_ID=
GA4_BIOCOM_SERVICE_ACCOUNT_KEY=
GSC_SITE_URL=sc-domain:biocom.kr
GSC_SERVICE_ACCOUNT_KEY=
OPENAI_API_KEY=
SERP_API_KEY=
PERPLEXITY_API_KEY=
PAGESPEED_API_KEY=

# Keep CRM senders disabled in the first VM cutover.
CHANNELTALK_MARKETING_ENABLED=false
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_PHONE=
ALIGO_KAKAOCHANNEL_ID=
