NODE_ENV=development
PORT=7020
TRUST_PROXY=0
LOG_LEVEL=debug
FRONTEND_ORIGIN=http://localhost:7010

# Background jobs
# Keep enabled on the single active origin only. During VM cutover, run the VM
# first with CAPI_AUTO_SYNC_ENABLED=false and ATTRIBUTION_STATUS_SYNC_ENABLED=false,
# then enable them only after the laptop backend is stopped.
BACKGROUND_JOBS_ENABLED=true
CWV_AUTO_SYNC_ENABLED=true
CAPI_AUTO_SYNC_ENABLED=true
CAPI_AUTO_SYNC_INTERVAL_MS=1800000
CAPI_AUTO_SYNC_LIMIT=100
ATTRIBUTION_STATUS_SYNC_ENABLED=true
ATTRIBUTION_STATUS_SYNC_INTERVAL_MS=900000
ATTRIBUTION_STATUS_SYNC_LIMIT=100

DATABASE_URL=postgresql://user:password@host:5432/dbname
REVENUE_API_BASE_URL=http://localhost:8000
REVENUE_API_BEARER_TOKEN=
GSC_SITE_URL=sc-domain:biocom.kr
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=change-me-please
REDIS_URL=
REDIS_PREFIX=biocom-seo:

# --- AI Citation (AEO) ---
# Google AI Overview (SerpAPI)
SERP_API_KEY=

# ChatGPT(Search) via OpenAI web_search
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
OPENAI_SEARCH_MODEL=gpt-4o-mini

# ChannelTalk
CHANNELTALK_PLUGIN_KEY=
CHANNELTALK_ACCESS_KEY=
CHANNELTALK_ACCESS_SECRET=
CHANNELTALK_MEMBER_HASH_SECRET=
CHANNELTALK_MARKETING_ENABLED=false

# Aligo
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_PHONE=
ALIGO_KAKAOCHANNEL_ID=

# Perplexity (optional)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# Toss Payments
# Legacy single-store names are still supported in code, but prefer the explicit multi-store names below.
TOSS_SHOP_ID_BIOCOM=
TOSS_LIVE_SECRET_KEY_BIOCOM=
TOSS_TEST_CLIENT_KEY_BIOCOM=
TOSS_TEST_SECRET_KEY_BIOCOM=

TOSS_SHOP_ID_COFFEE=
TOSS_LIVE_CLIENT_KEY_COFFEE=
TOSS_LIVE_SECRET_KEY_COFFEE=
TOSS_TEST_CLIENT_KEY_COFFEE=
TOSS_TEST_SECRET_KEY_COFFEE=

# Choose one auth method:
# 1) Path to service account key file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# 2) Raw JSON string in one line (escape newlines in private_key as \n)
# GSC_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id"}
